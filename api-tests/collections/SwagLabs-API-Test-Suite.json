    {
      "name": "2. JSONPlaceholder 资源CRUD - 6条",
      "item": [
        {
          "name": "[08] GET 资源列表 (分页+Schema契约)",
          "response": [
            {
              "name": "成功 - 返回100条posts数组",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[{\"userId\":1,\"id\":1,\"title\":\"...\",\"body\":\"...\"}]"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "const code = pm.response.code;",
                "pm.test('HTTP 200', () => pm.expect(code).to.equal(200));",
                "pm.test('返回Array (100条)', () => {",
                "  pm.expect(resp).to.be.an('array');",
                "  pm.expect(resp.length).to.equal(100);",
                "});",
                "pm.test('Schema: 每条含 userId/id/title/body 且类型正确', () => {",
                "  const item = resp[0];",
                "  pm.expect(item).to.have.all.keys('userId','id','title','body');",
                "  pm.expect(item.userId).to.be.a('number');",
                "  pm.expect(item.id).to.be.a('number');",
                "  pm.expect(item.title).to.be.a('string');",
                "  pm.expect(item.body).to.be.a('string');",
                "});",
                "pm.environment.set('latest_post_id', resp[resp.length - 1].id);",
                "console.log('[08] 获取' + resp.length + '条, last id=' + resp[resp.length - 1].id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts" }
          }
        },
        {
          "name": "[09] GET 单条资源 (id=1)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "pm.test('HTTP 200 + id=1', () => {",
                "  pm.expect(pm.response.code).to.equal(200);",
                "  pm.expect(resp.id).to.equal(1);",
                "  pm.expect(resp.userId).to.be.a('number');",
                "  pm.expect(resp.title).to.be.a('string').that.is.not.empty;",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/1" }
          }
        },
        {
          "name": "[10] POST 创建资源 (201契约)",
          "response": [
            {
              "name": "成功 - 201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"title\":\"swaglabs-test-title\",\"body\":\"api-test-body-content\",\"userId\":1,\"id\":101}"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "const code = pm.response.code;",
                "pm.test('HTTP 201 Created', () => pm.expect(code).to.equal(201));",
                "pm.test('含 id + 返回数据与请求一致', () => {",
                "  pm.expect(resp.id).to.equal(101);",
                "  pm.expect(resp.title).to.equal('swaglabs-test-title');",
                "  pm.expect(resp.body).to.equal('api-test-body-content');",
                "  pm.expect(resp.userId).to.equal(1);",
                "  pm.environment.set('last_created_id', resp.id);",
                "  let ids = pm.environment.get('created_post_ids') || '';",
                "  ids = ids ? ids + ',' + resp.id : String(resp.id);",
                "  pm.environment.set('created_post_ids', ids);",
                "  console.log('[10] 创建成功 id=' + resp.id + ' | 清理列表: [' + ids + ']');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json; charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"swaglabs-test-title\",\"body\":\"api-test-body-content\",\"userId\":1}" },
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts" }
          }
        },
        {
          "name": "[11] PUT 全量更新资源",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "pm.test('HTTP 200 + 全量更新生效', () => {",
                "  pm.expect(pm.response.code).to.equal(200);",
                "  pm.expect(resp.id).to.equal(1);",
                "  pm.expect(resp.title).to.equal('updated-title');",
                "  pm.expect(resp.body).to.equal('updated-body');",
                "});",
                "console.log('[11] PUT 更新成功');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json; charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\"id\":1,\"title\":\"updated-title\",\"body\":\"updated-body\",\"userId\":1}" },
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/1" }
          }
        },
        {
          "name": "[12] PATCH 局部更新资源",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "pm.test('HTTP 200 + 仅title被更新', () => {",
                "  pm.expect(pm.response.code).to.equal(200);",
                "  pm.expect(resp.title).to.equal('patched-title');",
                "});",
                "console.log('[12] PATCH 局部更新成功');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json; charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"patched-title\"}" },
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/1" }
          }
        },
        {
          "name": "[13] DELETE 删除资源",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const code = pm.response.code;",
                "pm.test('HTTP 200 (删除成功)', () => pm.expect(code).to.equal(200));",
                "pm.test('响应体为空对象', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(Object.keys(body).length).to.equal(0);",
                "});",
                "console.log('[13] DELETE 成功');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/1" }
          }
        }
      ]
    },
    {
      "name": "3. JSONPlaceholder 边界与安全 - 4条",
      "item": [
        {
          "name": "[14] GET 按条件过滤 (userId=1)",
          "response": [
            {
              "name": "成功 - 返回userId=1的posts数组",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[{\"userId\":1,\"id\":1,\"title\":\"...\",\"body\":\"...\"}]"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "pm.test('HTTP 200', () => pm.expect(pm.response.code).to.equal(200));",
                "pm.test('返回Array + Schema正确', () => {",
                "  pm.expect(resp).to.be.an('array');",
                "  pm.expect(resp.length).to.be.above(0);",
                "  pm.expect(resp[0]).to.have.all.keys('userId','id','title','body');",
                "});",
                "// JSONPlaceholder为假API，不实际过滤query参数，改为客户端过滤验证",
                "const filtered = resp.filter(item => item.userId === 1);",
                "pm.test('客户端过滤userId=1结果 > 0', () => pm.expect(filtered.length).to.be.above(0));",
                "pm.test('过滤结果全部userId=1', () => filtered.forEach(item => pm.expect(item.userId).to.equal(1)));",
                "console.log('[14] 总' + resp.length + '条, userId=1 → ' + filtered.length + '条');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts?userId=1" }
          }
        },
        {
          "name": "[15] GET 资源不存在 (id=99999)",
          "response": [
            {
              "name": "资源不存在 - 404",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{}"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const code = pm.response.code;",
                "pm.test('HTTP 404', () => pm.expect(code).to.equal(404));",
                "pm.test('响应体为空对象', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(Object.keys(body).length).to.equal(0);",
                "});",
                "console.log('[15] 404 资源不存在');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/99999" }
          }
        },
        {
          "name": "[16] GET 嵌套资源 (comments?postId=1)",
          "response": [
            {
              "name": "成功 - 返回5条评论数组",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[{\"postId\":1,\"id\":1,\"name\":\"...\",\"email\":\"...\",\"body\":\"...\"}]"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "pm.test('HTTP 200', () => pm.expect(pm.response.code).to.equal(200));",
                "pm.test('返回Array + Schema正确', () => {",
                "  pm.expect(resp).to.be.an('array');",
                "  pm.expect(resp.length).to.be.above(0);",
                "  pm.expect(resp[0]).to.have.all.keys('postId','id','name','email','body');",
                "});",
                "// JSONPlaceholder不实际过滤query参数，客户端筛选后验证",
                "const filtered = resp.filter(c => c.postId === 1);",
                "pm.test('客户端筛选postId=1正好5条', () => pm.expect(filtered.length).to.equal(5));",
                "console.log('[16] 总' + resp.length + '条, postId=1 → ' + filtered.length + '条');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "https://jsonplaceholder.typicode.com/comments?postId=1" }
          }
        },
        {
          "name": "[17] POST XSS注入健壮性",
          "response": [
            {
              "name": "成功 - 201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"title\":\"<script>alert(1)</script>\",\"body\":\"xss_test\",\"userId\":1,\"id\":101}"
            }
          ],
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const resp = pm.response.json();",
                "const code = pm.response.code;",
                "pm.test('非500崩溃 (返回201)', () => pm.expect(code).to.equal(201));",
                "pm.test('Schema完整 + 特殊字符未被截断', () => {",
                "  pm.expect(resp).to.have.all.keys('id','title','body','userId');",
                "  // 假API回显数据是预期行为，验证payload完整性即可",
                "  pm.expect(resp.title).to.include('script');",
                "  pm.expect(resp.title).to.include('alert');",
                "});",
                "console.log('[17] XSS测试: ' + code + ' | payload原样回显(假API预期行为)');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json; charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\"title\":\"<script>alert(1)</script>\",\"body\":\"xss_test\",\"userId\":1}" },
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts" }
          }
        }
      ]
    },
    {
      "name": "4. Teardown 清理",
      "item": [
        {
          "name": "[Teardown] 删除测试创建的资源",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const ids = pm.environment.get('created_post_ids');",
                "if (ids) {",
                "  console.log('Teardown: 清理 [' + ids + ']');",
                "  ids.split(',').forEach(function(id) {",
                "    if (id) {",
                "      pm.sendRequest({",
                "        url: 'https://jsonplaceholder.typicode.com/posts/' + id,",
                "        method: 'DELETE'",
                "      }, function(err, res) {",
                "        if (!err) { console.log('  已删除 id=' + id + ' -> ' + res.code); }",
                "        else { console.error('  删除失败 id=' + id); }",
                "      });",
                "    }",
                "  });",
                "  pm.environment.unset('created_post_ids');",
                "} else { console.log('Teardown: 无资源需清理'); }",
                "pm.environment.unset('last_created_id');",
                "console.log('Teardown: 完成');"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "https://jsonplaceholder.typicode.com/posts/{{last_created_id}}" }
          }
        }
      ]
    }
  ]
}
